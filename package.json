{
  "name": "@beequeue/dota-matches-api",
  "type": "module",
  "version": "0.0.0",
  "author": "BeeeQueue <adam@haglund.dev>",
  "license": "CC-BY-SA-3.0-US",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": "^26"
  },
  "simple-git-hooks": {
    "pre-commit": "node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,json5,yaml,yml,css,scss,md}": [
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:migrate": "wrangler d1 migrations apply --local dpc",
    "gen:types": "wrangler types",
    "build": "tsdown",
    "lint": "oxlint",
    "test": "vitest",
    "test:e2e": "vitest  -c vitest.e2e.config.ts",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260717.1",
    "@e18e/eslint-plugin": "0.5.1",
    "@leeoniya/ufuzzy": "1.0.19",
    "@total-typescript/ts-reset": "0.6.1",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/node26": "26.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "26.1.1",
    "db0": "0.3.4",
    "discord-api-types": "0.38.50",
    "discord-interactions": "4.4.0",
    "es-toolkit": "1.49.0",
    "h3": "2.0.1-rc.25",
    "kysely": "0.29.4",
    "mentoss": "0.13.0",
    "milli": "4.0.0",
    "miniflare": "4.20260714.0",
    "nano-staged": "1.0.2",
    "nanoid": "6.0.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "p-queue": "9.3.1",
    "simple-git-hooks": "2.13.1",
    "temporal-polyfill-lite": "0.4.2",
    "tsdown": "0.22.9",
    "typescript": "6.0.3",
    "ultrahtml": "1.7.0",
    "unrun": "0.3.1",
    "vitest": "5.0.0-beta.6",
    "wrangler": "4.112.0",
    "xior": "0.8.3"
  }
}
